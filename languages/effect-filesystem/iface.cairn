f = family Filesystem ;
k = kind filesystem ;
p = path "Path" ;
a1 = action read ;
a2 = action write ;
a3 = action mkdirs ;
g1 = gate read read ;
g2 = gate readBytes read ;
g3 = gate exists read ;
g4 = gate isDirectory read ;
g5 = gate isRegularFile read ;
g6 = gate isExecutable read ;
g7 = gate list read ;
g8 = gate write write ;
g9 = gate writeBytes write ;
g10 = gate delete write ;
g11 = gate mkdirs mkdirs ;
g12 = gate createTempDirectory mkdirs ;
u1 = ungated resolve ;

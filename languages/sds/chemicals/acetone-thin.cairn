acetoneOutline = outline "Acetone" "67-64-1" sections (s1, s2, s16) ;
s1 = identification section (productName "Acetone" synonyms "2-Propanone; propan-2-one" recommendedUse "Laboratory reagent; solvent for coatings, adhesives, and cleaning." usesAdvisedAgainst "Food, drug, pesticide, or biocidal product use." supplierName "Cairn Chemicals Demo Ltd. (fictional, for demonstration only)" emergencyPhone "+32 000 000 000 (demo number)" locales (productName lang fr : "Acétone", synonyms lang fr : "propan-2-one ; 2-propanone", recommendedUse lang fr : "Réactif de laboratoire ; solvant pour revêtements, adhésifs et nettoyage.", supplierName lang fr : "Cairn Chemicals Demo Ltd. (fictionnel, à des fins de démonstration uniquement)")) ;
s16 = eu section 16 fields (revisionDate lang en : "2026-07-22", otherInformation lang en : "Demo/example data for the Cairn SDS chemicals corpus — not regulatory or safety advice for real use.", otherInformation lang fr : "Données de démonstration / exemple pour le corpus chimiques SDS Cairn — pas un conseil réglementaire ou de sécurité pour un usage réel.") ;
s2 = hazards section (classificationSummary "Flammable liquid Category 2; Serious eye damage/eye irritation Category 2; STOT SE Category 3 (CNS) — Regulation (EC) No 1272/2008" hazardsNotOtherwiseClassified "Repeated exposure may cause skin dryness or cracking." hazardPhrases "H225; H319; H336" signalWord "Danger" pictograms "GHS02; GHS07" locales (classificationSummary lang fr : "Liquide inflammable catégorie 2 ; lésions oculaires graves/irritation oculaire catégorie 2 ; STOT SE catégorie 3 (SNC) — règlement (CE) n° 1272/2008", hazardPhrases lang fr : "H225 ; H319 ; H336", signalWord lang fr : "Danger", pictograms lang fr : "GHS02 ; GHS07")) ;

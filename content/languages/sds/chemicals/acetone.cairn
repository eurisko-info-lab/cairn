acetoneOutline = outline "Acetone" "67-64-1" sections (s1, s2, s3, s4, s5, s6, s7, s8, s9, s10, s11, s12, s13, s14, s15, s16) ;
s1 = eu section 1 fields (synonyms lang en : "2-Propanone; propan-2-one", recommendedUse lang en : "Laboratory reagent; solvent for coatings, adhesives, and cleaning.", usesAdvisedAgainst lang en : "Food, drug, pesticide, or biocidal product use.", supplierName lang en : "Cairn Chemicals Demo Ltd. (fictional, for demonstration only)", productName lang en : "Acetone", emergencyPhone lang en : "+32 000 000 000 (demo number)") ;
s10 = eu section 10 fields (stability lang en : "Stable under recommended storage conditions.", conditionsToAvoid lang en : "Heat, flames, and sparks.", incompatibleMaterials lang en : "Strong oxidizing agents, strong bases, peroxides, halogenated compounds, alkali metals, amines.", hazardousDecomposition lang en : "CO, CO2, formaldehyde, methanol under fire conditions.") ;
s11 = eu section 11 fields (LD50Oral lang en : "5800 mg/kg (rat, oral)", irritation lang en : "Causes serious eye irritation. Prolonged skin contact may cause dryness.", inhalationEffects lang en : "Vapours may cause drowsiness and dizziness.", carcinogenicity lang en : "Not listed as a carcinogen by IARC, NTP, ACGIH, or OSHA.") ;
s12 = eu section 12 fields (ecotoxicity lang en : "Fish LC50 ~5540 mg/L (96h); daphnia EC50 ~8800 mg/L (48h).", persistence lang en : "Readily biodegradable; persistence unlikely.", bioaccumulation lang en : "Low (log Pow = -0.24).", mobility lang en : "Likely mobile due to volatility.") ;
s13 = eu section 13 fields (disposalMethods lang en : "Dispose per local/regional/national regulations. Do not discharge to drains.", wasteClassification lang en : "Consult local regulations; US RCRA U002 is often cited for acetone waste.") ;
s14 = eu section 14 fields (unNumber lang en : "UN1090", properShippingName lang en : "ACETONE", transportHazardClass lang en : "Class 3 (Flammable liquid)", packingGroup lang en : "II") ;
s15 = eu section 15 fields (regulatoryInfo lang en : "Classified and labelled per Regulation (EC) No 1272/2008 (CLP).", reachStatus lang en : "Subject to REACH Annex XVII entry 75 use restriction (demo note).", usInventory lang en : "Listed on US TSCA Inventory (active).") ;
s16 = eu section 16 fields (revisionDate lang en : "2026-07-22", otherInformation lang en : "Demo/example data for the Cairn SDS chemicals corpus — not regulatory or safety advice for real use.") ;
s2 = eu section 2 fields (hazardPhrases lang en : "H225; H319; H336", pictograms lang en : "GHS02; GHS07", hazardsNotOtherwiseClassified lang en : "Repeated exposure may cause skin dryness or cracking.", signalWord lang en : "Danger", classificationSummary lang en : "Flammable liquid Category 2; Serious eye damage/eye irritation Category 2; STOT SE Category 3 (CNS) — Regulation (EC) No 1272/2008") ;
s3 = eu section 3 fields (componentName lang en : "Acetone", cas lang en : "67-64-1", ec lang en : "200-662-2", concentration lang en : ">= 99.5 %") ;
s4 = eu section 4 fields (generalAdvice lang en : "If symptoms persist, call a physician.", skinContact lang en : "Wash off with soap and plenty of water. Remove contaminated clothing.", inhalation lang en : "Remove to fresh air. If breathing is difficult, give oxygen.", ingestion lang en : "Rinse mouth. Do NOT induce vomiting.", eyeContact lang en : "Rinse cautiously with water for several minutes. Remove contact lenses if present.") ;
s5 = eu section 5 fields (extinguishingMedia lang en : "Water spray, alcohol-resistant foam, dry chemical, or carbon dioxide.", unsuitableExtinguishingMedia lang en : "Water may be ineffective as the primary extinguishing agent.", specialHazards lang en : "Vapours may form explosive mixtures with air; containers may rupture when heated.", firefighterProtection lang en : "Wear SCBA and full protective gear.") ;
s6 = eu section 6 fields (personalPrecautions lang en : "Remove ignition sources. Ventilate. Wear appropriate PPE.", environmentalPrecautions lang en : "Prevent entry into drains and waterways.", cleanupMethods lang en : "Contain spill; soak up with inert absorbent; dispose as hazardous waste.") ;
s7 = eu section 7 fields (handling lang en : "Avoid contact with skin and eyes. Use only in well-ventilated areas. Keep away from heat and open flames.", storage lang en : "Store cool, well-ventilated, away from ignition sources. Keep container tightly closed.", storageIncompatibilities lang en : "Strong oxidizers, strong reducers, strong bases, peroxides, halogenated compounds, alkali metals, amines.") ;
s8 = eu section 8 fields (respiratoryProtection lang en : "Organic vapor respirator (type AX) if exposure limits exceeded.", skinProtection lang en : "Protective gloves and clothing.", occupationalExposureLimit lang en : "EU indicative OELV 500 ppm (1210 mg/m3), 8-hour TWA; ACGIH TWA 250 ppm / STEL 500 ppm.", eyeProtection lang en : "Chemical safety goggles (e.g. EN166).", engineeringControls lang en : "Adequate ventilation; explosion-proof electrical equipment; eyewash nearby.") ;
s9 = eu section 9 fields (solubility lang en : "Miscible with water in all proportions.", boilingPoint lang en : "56.05 degC at 1013 hPa", density lang en : "0.79 g/cm3 at 20 degC", appearance lang en : "Colourless liquid.", molecularWeight lang en : "58.08 g/mol", meltingPoint lang en : "-94.7 degC", flashPoint lang en : "-20 degC (closed cup)", explosiveLimits lang en : "Lower 2.5% / Upper 13% (v/v in air)", odor lang en : "Characteristic, sweetish (mint-like).") ;

ethanolOutline = outline "Ethanol" "64-17-5" sections (s1, s2, s3, s4, s5, s6, s7, s8, s9, s10, s11, s12, s13, s14, s15, s16) ;
s1 = eu section 1 fields (synonyms lang en : "Ethyl alcohol; ethanol absolute; spirit of wine", recommendedUse lang en : "Laboratory reagent; solvent; disinfectant formulation feedstock.", usesAdvisedAgainst lang en : "Food, drug, or biocidal product use without further authorisation.", supplierName lang en : "Cairn Chemicals Demo Ltd. (fictional, for demonstration only)", productName lang en : "Ethanol", emergencyPhone lang en : "+32 000 000 000 (demo number)") ;
s10 = eu section 10 fields (stability lang en : "Stable under recommended storage conditions.", conditionsToAvoid lang en : "Heat, flames, sparks, and static discharge.", incompatibleMaterials lang en : "Strong oxidizing agents, alkali metals, strong acids, peroxides.", hazardousDecomposition lang en : "CO, CO2 under fire conditions.") ;
s11 = eu section 11 fields (ld50Oral lang en : "7060 mg/kg (rat, oral)", irritation lang en : "Causes serious eye irritation. Prolonged skin contact may cause dryness.", inhalationEffects lang en : "High vapour concentrations may cause dizziness and narcosis.", carcinogenicity lang en : "IARC Group 1 for alcoholic beverages; ethanol as industrial substance not classified as a carcinogen in this demo note.") ;
s12 = eu section 12 fields (ecotoxicity lang en : "Fish LC50 ~14200 mg/L (96h); daphnia EC50 ~9268 mg/L (48h).", persistence lang en : "Readily biodegradable; persistence unlikely.", bioaccumulation lang en : "Low (log Pow = -0.31).", mobility lang en : "Likely mobile in soil and water due to miscibility.") ;
s13 = eu section 13 fields (disposalMethods lang en : "Dispose per local/regional/national regulations. Do not discharge to drains.", wasteClassification lang en : "Consult local regulations; flammable liquid waste stream.") ;
s14 = eu section 14 fields (unNumber lang en : "UN1170", properShippingName lang en : "ETHANOL (ETHYL ALCOHOL) or ETHANOL SOLUTION", transportHazardClass lang en : "Class 3 (Flammable liquid)", packingGroup lang en : "II") ;
s15 = eu section 15 fields (regulatoryInfo lang en : "Classified and labelled per Regulation (EC) No 1272/2008 (CLP).", reachStatus lang en : "Registered under REACH (demo note).", usInventory lang en : "Listed on US TSCA Inventory (active).") ;
s16 = eu section 16 fields (revisionDate lang en : "2026-07-22", otherInformation lang en : "Demo/example data for the Cairn SDS chemicals corpus (secondary ethanol) — not regulatory or safety advice for real use.") ;
s2 = eu section 2 fields (hazardPhrases lang en : "H225; H319", pictograms lang en : "GHS02; GHS07", hazardsNotOtherwiseClassified lang en : "Highly flammable liquid and vapour; vapours may form explosive mixtures with air.", signalWord lang en : "Danger", classificationSummary lang en : "Flammable liquid Category 2; Serious eye damage/eye irritation Category 2 — Regulation (EC) No 1272/2008") ;
s3 = eu section 3 fields (componentName lang en : "Ethanol", cas lang en : "64-17-5", ec lang en : "200-578-6", concentration lang en : ">= 99.5 %") ;
s4 = eu section 4 fields (generalAdvice lang en : "If symptoms persist, call a physician.", skinContact lang en : "Wash off with soap and plenty of water. Remove contaminated clothing.", inhalation lang en : "Remove to fresh air. If breathing is difficult, give oxygen.", ingestion lang en : "Rinse mouth. Do NOT induce vomiting.", eyeContact lang en : "Rinse cautiously with water for several minutes. Remove contact lenses if present.") ;
s5 = eu section 5 fields (extinguishingMedia lang en : "Alcohol-resistant foam, dry chemical, or carbon dioxide.", unsuitableExtinguishingMedia lang en : "Water jet may spread the fire.", specialHazards lang en : "Vapours may travel to ignition source and flash back; containers may rupture when heated.", firefighterProtection lang en : "Wear SCBA and full protective gear.") ;
s6 = eu section 6 fields (personalPrecautions lang en : "Remove ignition sources. Ventilate. Wear appropriate PPE.", environmentalPrecautions lang en : "Prevent entry into drains and waterways.", cleanupMethods lang en : "Contain spill; soak up with inert absorbent; dispose as hazardous waste.") ;
s7 = eu section 7 fields (handling lang en : "Keep away from heat, sparks, and open flames. Use only in well-ventilated areas.", storage lang en : "Store cool, well-ventilated, away from ignition sources. Keep container tightly closed.", storageIncompatibilities lang en : "Strong oxidizers, alkali metals, strong acids, peroxides.") ;
s8 = eu section 8 fields (respiratoryProtection lang en : "Organic vapor respirator if exposure limits exceeded.", skinProtection lang en : "Protective gloves and clothing.", occupationalExposureLimit lang en : "EU indicative OELV 1000 ppm (1920 mg/m3), 8-hour TWA; ACGIH STEL 1000 ppm.", eyeProtection lang en : "Chemical safety goggles (e.g. EN166).", engineeringControls lang en : "Adequate ventilation; explosion-proof electrical equipment; eyewash nearby.") ;
s9 = eu section 9 fields (solubility lang en : "Miscible with water in all proportions.", boilingPoint lang en : "78.3 degC at 1013 hPa", density lang en : "0.79 g/cm3 at 20 degC", appearance lang en : "Colourless liquid.", molecularWeight lang en : "46.07 g/mol", meltingPoint lang en : "-114.1 degC", flashPoint lang en : "13 degC (closed cup)", explosiveLimits lang en : "Lower 3.3% / Upper 19% (v/v in air)", odor lang en : "Characteristic, alcoholic.") ;

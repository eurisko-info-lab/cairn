-- Ported from Marble/Charb `hardening-phase5-workflow.yaml`
-- Source-file: hardening-phase5-workflow.yaml
-- Description: Phase 5 decentralization hardening command coverage
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript hardening-phase5 {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

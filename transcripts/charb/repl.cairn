-- Ported from Marble/Charb `repl-workflow.yaml`
-- Source: ~/Projects/all-git-repos/pi-forall/charb/transcripts/repl-workflow.yaml
-- Description: Real repl eval/history/clear command flow
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript repl {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  roundtrip "fun x : Bool . x" ;
  eval "true" expect "true" ;
  publish tip ;
  fetch tip ;
}

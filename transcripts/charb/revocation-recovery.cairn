-- Ported from Marble/Charb `revocation-recovery-workflow.yaml`
-- Source-file: revocation-recovery-workflow.yaml
-- Description: Publish → revoke → supersede → range resolve skips revoked → lock → evidence reuse
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript revocation-recovery {
  load-language "languages/pki.cairn" ;
  lang pki ;
  roundtrip "revoked alice reason \"compromise\" at \"1000\"" ;
  delta "{ add soft = revoked alice reason \"compromise\" at \"1000\" ; }" ;
  publish trust ;
  fetch trust ;
}

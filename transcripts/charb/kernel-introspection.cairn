-- Description: Enhanced kernel inspection with event counts and diagnostics
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript kernel-introspection {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  roundtrip "fun x : Bool . x" ;
  eval "true" expect "true" ;
  publish tip ;
  fetch tip ;
}

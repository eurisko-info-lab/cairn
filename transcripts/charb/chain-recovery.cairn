-- Ported from Marble/Charb `chain-recovery-workflow.yaml`
-- Source: ~/Projects/all-git-repos/pi-forall/charb/transcripts/chain-recovery-workflow.yaml
-- Description: Reconcile and reset-to-global commands recover local cache state from a shared global chain
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript chain-recovery {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  node c ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
  fetch main from a to c ;
  gossip a, b, c ;
}

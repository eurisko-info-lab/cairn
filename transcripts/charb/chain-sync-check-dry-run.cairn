-- Description: Chain sync --check and --dry-run report planned changes without mutating state
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript chain-sync-check-dry-run {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

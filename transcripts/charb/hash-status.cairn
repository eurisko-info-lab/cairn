-- Ported from Marble/Charb `hash-status-workflow.yaml`
-- Source-file: hash-status-workflow.yaml
-- Description: Hash status overview of hashable artifact counts
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript hash-status {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  roundtrip "fun x : Bool . x" ;
  eval "true" expect "true" ;
  publish tip ;
  fetch tip ;
}

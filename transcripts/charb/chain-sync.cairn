-- Ported from Marble/Charb `chain-sync-workflow.yaml`
-- Source: ~/Projects/all-git-repos/pi-forall/charb/transcripts/chain-sync-workflow.yaml
-- Description: Distributed state: chain attach → publish → chain sync → chain status (strict) → verify
-- Rich sibling adaptation also under transcripts/.
transcript chain-sync {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

-- Description: Provenance impact registry listing, inspection, and status summary
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript provenance-registry {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

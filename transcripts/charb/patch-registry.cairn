-- Source-revision: f1c8dbdf387595ae5505e8ef0090c05fd595aa70
-- Description: Patch registry listing, inspection, and status summary
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript patch-registry {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  delta "{ add id = fun x : Bool . x ; add both = (id true) ; }" ;
  expectfail "footprint mismatch" delta "{ rename id to ident footprint [] ; }" ;
}

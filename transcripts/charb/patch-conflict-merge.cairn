-- Ported from Marble/Charb `patch-conflict-merge-workflow.yaml`
-- Source-file: patch-conflict-merge-workflow.yaml
-- Description: Conflicting patches: composeSequentially stays dirty, preferLeft resolves clean
-- Rich sibling adaptation also under transcripts/.
transcript patch-conflict-merge {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

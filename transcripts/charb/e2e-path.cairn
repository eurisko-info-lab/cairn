-- Description: One-shot kernel demo: e2e path through full lifecycle, then run object
-- Rich sibling adaptation also under transcripts/.
transcript e2e-path {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

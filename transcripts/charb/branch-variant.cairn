-- Description: History workflow: publish baseline → branch → variant → commit record → patch apply → verify
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript branch-variant {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

-- Description: Audit root history and governance replay history are recorded and inspectable
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript replay-history {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  node c ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
  fetch main from a to c ;
  gossip a, b, c ;
}

-- Description: E2E status and inspect commands for per-package path visibility
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript e2e-registry {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
}

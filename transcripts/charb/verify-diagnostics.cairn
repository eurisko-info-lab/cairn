-- Description: Verify status and inspect diagnostic commands over a populated repo
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript verify-diagnostics {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  roundtrip "fun x : Bool . x" ;
  eval "true" expect "true" ;
  publish tip ;
  fetch tip ;
}

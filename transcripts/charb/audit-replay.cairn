-- Ported from Marble/Charb `audit-replay-workflow.yaml`
-- Source-file: audit-replay-workflow.yaml
-- Description: Chain event replay with hash accumulator and tamper detection
-- Thin Cairn mapping of the Charb theme (not a CLI clone).
transcript audit-replay {
  load-language "languages/stlc.cairn" ;
  lang stlc ;
  node a ;
  node b ;
  node c ;
  delta "{ add tip = fun x : Bool . x ; }" ;
  publish main on a ;
  fetch main from a to b ;
  fetch main from a to c ;
  gossip a, b, c ;
}

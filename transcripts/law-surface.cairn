-- Adapted from GRANITE Law pack / CAIRN-PROMPT Phase 8 (PKI → Law → SDS).
-- Source: ~/GRANITE/examples/law/ — statute surface + free ΔLaw add/remove.
-- Citation judgments stay in LawTutorial (host).
-- Run: sbt "examples/runMain cairn.examples.Main transcript transcripts/law-surface.cairn"
transcript law-surface {
  load-language "languages/law.cairn" ;
  lang law ;
  roundtrip "section \"1\" heading \"Purpose\" text \"This Act governs chemical safety disclosure.\"" ;
  roundtrip "enactedBy act cert root" ;
  delta "{ add s1 = section \"1\" heading \"Purpose\" text \"This Act governs chemical safety disclosure.\" ; }" ;
  delta "{ add s3 = section \"3\" heading \"SDS duty\" text \"Publishers must maintain an SDS.\" ; }" ;
  roundtrip "cites \"3\" \"1\"" ;
  delta "{ add s3cites1 = cites \"3\" \"1\" ; }" ;
  delta "{ add act = statute \"Model Chemical Safety Act\" sections ( s1 , s3 ) ; }" ;
  delta "{ add authority = enactedBy act cert root ; }" ;
  publish statutes ;
  fetch statutes ;
}
